# Copy this file to .env and fill in keys for the providers you want to use
# You only need keys for providers you actually use

# Anthropic Claude  →  https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI ChatGPT  →  https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Google Gemini  →  https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# Groq (free tier available)  →  https://console.groq.com/
GROQ_API_KEY=gsk_...

# Mistral AI  →  https://console.mistral.ai/
MISTRAL_API_KEY=...

# DeepSeek (very cheap)  →  https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-...

# NVIDIA NIM / build.nvidia.com  →  https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-...

# Cohere  →  https://dashboard.cohere.com/api-keys
COHERE_API_KEY=...

# Tavily Search  →  https://app.tavily.com/
TAVILY_API_KEY=tvly-...

# Ollama runs locally — no API key needed
# Install: https://ollama.com  then: ollama pull llama3.2
